# ==========================================
# Configurações Globais da Infraestrutura (TEMPLATE)
# ==========================================

# 1. Configurações de Rede (Interfaces)
IF_WAN="<SUA_INTERFACE_WAN_AQUI>" # ex: enps03
IF_LAN="<SUA_INTERFACE_LAN_AQUI>" # ex: enps08

# Endereço IP do servidor na LAN (Atuará como Gateway e DNS na rede)
IP_LAN="10.0.0.1"
SUBNET_LAN="10.0.0.0"
NETMASK="255.255.255.0"

# 2. Configurações do Active Directory (Samba 4)
DOMAIN_REALM="empresa.local"
DOMAIN_NETBIOS="EMPRESA"
ADMIN_PASSWORD="SuaPasswordSegura2026!"
FUNCTIONAL_LEVEL="2012_R2"

# 3. Configurações de DHCP
DHCP_RANGE_START="10.0.0.100"
DHCP_RANGE_END="10.0.0.200"
DHCP_GATEWAY="10.0.0.1"
DHCP_DNS1="10.0.0.1"
DHCP_DNS2="8.8.8.8"

# 4. Configuração de Partilha de Ficheiros (File Server)
SHARE_BASE_DIR="/srv/samba/shares"
PUBLIC_SHARE_NAME="Publico"
RESTRICTED_SHARE_NAME="Direcao"
RESTRICTED_GROUP="Domain Admins"

# 5. Configurações de Backup Diário
BACKUP_DEST_DIR="/var/backups/infra-aster"
BACKUP_RETENTION_DAYS="7"

# 6. Monitorização (Prometheus + Grafana)
GRAFANA_ADMIN_PASSWORD="SuaPasswordGrafana!"

# 7. VPN Corporativa (OpenVPN)
OVPN_PORT="1194"
OVPN_PROTO="udp"
OVPN_SUBNET="10.8.0.0"
OVPN_NETMASK="255.255.255.0"
OVPN_PUBLIC_IP="SEU_IP_PUBLICO_AQUI"
